# 基础镜像
FROM eclipse-temurin:21 

 # 安装 Node.js                                                                                                                                                                    
  RUN apt-get update && apt-get install -y curl xz-utils && \
      curl -fsSL https://npmmirror.com/mirrors/node/v18.20.4/node-v18.20.4-linux-x64.tar.xz -o /tmp/node.tar.xz && \
      tar -xJf /tmp/node.tar.xz -C /usr/local --strip-components=1 && \
      rm /tmp/node.tar.xz && \
      npm config set registry https://registry.npmmirror.com && \
      npm install -g @amap/amap-maps-mcp-server && \
      apt-get clean && rm -rf /var/lib/apt/lists/* && \
      node --version && npm --version && npx --version

    
# 验证安装
RUN node --version && npx --version

# 设定时区
ENV TZ=Asia/Shanghai
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

# 激活生产环境 profile（使用 mcp-servers-linux.json）
ENV SPRING_PROFILES_ACTIVE=prod

# 拷贝jar包
COPY ./backend/my-agent-0.0.1-SNAPSHOT.jar /app.jar

# 入口
ENTRYPOINT ["java", "-jar", "/app.jar"]